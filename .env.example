# Supabase project URL, without `/rest/v1`.
# Example shape: https://your-project-ref.supabase.co
SUPABASE_URL=

# Supabase anon/public key.
# Safe for frontend use, but still keep real values out of git.
SUPABASE_ANON_KEY=
SUPABASE_PUBLISHABLE_KEY=

# Frontend copies of the same public Supabase values.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# Supabase service role secret key.
# Backend/server only. Never expose in VITE_*, frontend code, screenshots, or public repos.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only Gemini API key for AI-generated quizzes.
# Never expose this as VITE_*.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
